---
import { Icon } from "astro-icon/components";
---

<footer class="bg-zinc-900 text-zinc-300 mt-2 border-t border-zinc-800">

  <div class="w-full px-6 md:px-16 py-12 flex flex-col md:flex-row justify-between items-start gap-12">

    <!-- COLUMNA 1: CONTACTO -->
    <div class="w-full md:w-1/2 mx-auto md:mx-0">
      <div class="flex flex-col md:flex-row text-left items-center justify-center gap-12">
        <div class="w-full max-w-5xl text-left">
          <h3 class="text-start w-40 text-white text-md md:text-xl font-bold mb-6 mx-auto md:mx-0">
            Contacto
          </h3>
          <ul class="space-y-4 text-xs md:text-base w-fit mx-auto md:mx-0">
            <li class="flex flex-row gap-3">
              <Icon name="lucide:user" class="h-5 w-5 text-lime-400 md:mt-1" />
              Germán Martínez
            </li>
            <li class="flex flex-row gap-3">
              <Icon name="lucide:mail" class="h-5 w-5 text-lime-400 md:mt-1" />
              <a href="mailto:germanmtz96@gmail.com" class="hover:text-lime-400 transition">
                germanmtz96@gmail.com
              </a>
            </li>
            <li class="flex flex-row gap-3">
              <Icon name="lucide:phone" class="h-5 w-5 text-lime-400 md:mt-1" />
              <a href="tel:+34637651578" class="hover:text-lime-400 transition">
                +34 637 65 15 78
              </a>
            </li>
            <li class="flex flex-row gap-3">
              <Icon name="lucide:map-pin" class="h-5 w-5 text-lime-400 md:mt-1" />
              Alicante, España
            </li>
        </div>
        <div>
          <img 
            src="/src/public/imgi_1_logo_complete.webp" 
            alt="Logo Academia"
            class="h-15 md:h-25 w-auto"
          />
        </div>
      </div>
      </ul>
    </div>


    <!-- COLUMNA 2: MAPA -->
    <div class="flex justify-center w-full md:w-1/3">
      <div class="rounded-xl overflow-hidden shadow-lg">
        <iframe 
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d68450.56675491917!2d-0.6305576889008419!3d38.34507573775475!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd6231c2ca933c11%3A0xc8ff8c3291129495!2sClub%20de%20padel%20y%20tenis%20Mutxamel!5e1!3m2!1ses!2ses!4v1771602443653!5m2!1ses!2ses"
          width="100%" 
          height="220" 
          style="border:0;" 
          loading="lazy" 
          class="rounded-xl"
        ></iframe>
      </div>
    </div>

    <!-- COLUMNA 3: INFORMACION ENLACES -->
    <div class="flex flex-row justify-center w-full md:w-1/5 gap-20 mx-auto">
      <div>

        <h3 class="text-white text-lg md:text-xl font-bold mb-6 w-fit mx-auto">Información</h3>
        <ul class="space-y-4 text-sm md:text-base w-fit mx-auto">
          <li class="flex items-start md:justify-start gap-3">
            <a href="/sobre-nosotros" class="hover:text-lime-400 transition">
              Sobre Nosotros
            </a>
          </li>
          <li class="flex items-start md:justify-start gap-3">
            <a href="/reglas" class="hover:text-lime-400 transition">
              Reglas
            </a>
          </li>
          <li class="flex items-start md:justify-start gap-3">
            <a href="/como-participar" class="hover:text-lime-400 transition">
              Cómo Participar
            </a>
          </li>
        </ul>
      </div>

      <div >
      <h3 class="text-white text-lg md:text-xl font-bold mb-6 w-fit mx-auto">Edición 25</h3>
      <ul class="space-y-4 text-sm md:text-base w-fit mx-auto">
        <li class="flex items-start md:justify-start gap-3">
          <a href="/clasificacion/2025" class="hover:text-lime-400 transition">
            Clasificación
          </a>
        </li>
        <li class="flex items-start md:justify-start gap-3">
          <a href="/participantes/2025" class="hover:text-lime-400 transition">
            Participantes
          </a>
        </li>
        <li class="flex items-start md:justify-start gap-3">
          <a href="/partidos/2025" class="hover:text-lime-400 transition">
            Partidos
          </a>
        </li>
      </ul>
    </div>
    </div>

  </div>

  <!-- COPYRIGHT -->
  <div class="border-t border-zinc-800 text-center text-sm py-6 text-zinc-500">
    © 2025 Torneo Cumpleaños GR.
  </div>

</footer>