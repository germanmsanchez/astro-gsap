---
const currentPath = Astro.url.pathname;
---

<header class="w-full bg-zinc-900/80 backdrop-blur-md fixed top-0 left-0 z-50">
  <div class="mx-auto max-w-7xl md:max-w-full flex justify-between items-center px-4 md:px-8 h-16 md:h-30">
    <a href="/" class="flex items-center">
      <img 
        src="/src/public/logo.png" 
        alt="Logo Torneo"
        class="h-15 md:h-30 w-auto"
      />
    </a>
    <button 
      id="menu-btn"
      class="md:hidden text-white focus:outline-none"
      aria-label="Abrir menú"
    >
      <svg xmlns="http://www.w3.org/2000/svg" 
        class="w-6 h-6" 
        fill="none" 
        viewBox="0 0 24 24" 
        stroke="currentColor" 
        stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" 
          d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <nav class="hidden md:flex items-center gap-12 text-sm font-semibold uppercase tracking-wider">
      <a 
        href="/clasificacion" 
        class={`transition hover:text-lime-400 ${currentPath === "/clasificacion" ? "text-lime-400" : ""}`}
      >
        Clasificación
      </a>

      <a 
        href="/participantes" 
        class={`transition hover:text-lime-400 ${currentPath === "/participantes" ? "text-lime-400" : ""}`}
      >
        Participantes
      </a>

      <a 
        href="/partidos" 
        class={`transition hover:text-lime-400 ${currentPath === "/partidos" ? "text-lime-400" : ""}`}
      >
        Partidos
      </a>
    </nav>
  </div>

  <div 
    id="mobile-menu"
    class="md:hidden hidden flex-col bg-zinc-900 border-t border-zinc-800 px-6 py-6 space-y-6 text-sm font-semibold uppercase tracking-wider"
  >
    <a 
      href="/clasificacion" 
      class={`block transition hover:text-lime-400 ${currentPath === "/clasificacion" ? "text-lime-400" : ""}`}
    >
      Clasificación
    </a>

    <a 
      href="/participantes" 
      class={`block transition hover:text-lime-400 ${currentPath === "/participantes" ? "text-lime-400" : ""}`}
    >
      Participantes
    </a>

    <a 
      href="/partidos" 
      class={`block transition hover:text-lime-400 ${currentPath === "/partidos" ? "text-lime-400" : ""}`}
    >
      Partidos
    </a>
  </div>

  <script>
    const btn = document.getElementById('menu-btn');
    const menu = document.getElementById('mobile-menu');

    btn?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
    });
  </script>
</header>
