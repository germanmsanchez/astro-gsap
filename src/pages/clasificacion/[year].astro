                  <th class="px-3 py-3 md:px-6 md:py-4 font-semibold">Jugador</th>

                  <th class="px-3 py-3 md:px-6 md:py-4 font-semibold hidden md:table-cell">Grupo</th>

                  <th class="px-3 py-3 md:px-6 md:py-4 font-semibold">
                    <span class="md:hidden">Pts.</span>
                    <span class="hidden md:inline">Puntos</span>
                  </th>
                    <th class="px-3 py-3 md:px-6 md:py-4 font-semibold hidden md:table-cell">Partidos</th>
                  <th class="px-3 py-3 md:px-6 md:py-4 font-semibold">
                    <span class="md:hidden inline-flex items-center" aria-label="Subidas">
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="22 7 13.5 15.5 8.5 10.5 2 17" />
                        <polyline points="16 7 22 7 22 13" />
                      </svg>
                    </span>
                    <span class="hidden md:inline">Ganados</span>
                  </th>

                  <th class="px-3 py-3 md:px-6 md:py-4 font-semibold">
                    <span class="md:hidden inline-flex items-center" aria-label="Bajadas">
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="22 17 13.5 8.5 8.5 13.5 2 7" />
                        <polyline points="16 17 22 17 22 11" />
                      </svg>
                    </span>
                    <span class="hidden md:inline">Perdidos</span>
                  </th>
                </tr>
              </thead>

              <tbody class="text-zinc-200">
                {all1.map((r, idx) => (
                  <tr class={`border-b border-zinc-900/60 ${idx < 3 ? "bg-lime-400/5" : ""}`}>
                    <td class="px-3 py-3 md:px-6 md:py-4 font-semibold">{rankInList(all1, idx)}</td>
                    <td class="px-3 py-3 md:px-6 md:py-4 font-semibold text-white">{r.jugador}</td>

                    <td class="px-3 py-3 md:px-6 md:py-4 hidden md:table-cell">
                      <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs border border-lime-400/40 text-lime-300 bg-lime-400/10">
                        {groupLabel(r.grupo)}
                      </span>
                    </td>

                    <td class="px-3 py-3 md:px-6 md:py-4 font-bold text-lime-400">{r.puntos}</td>

                    {year === "2026" ? (
                      <td class="px-3 py-3 md:px-6 md:py-4 hidden md:table-cell">{r.pista1_min ?? 0}</td>
                    ) : (
                      <td class="px-3 py-3 md:px-6 md:py-4 hidden md:table-cell">
                        {(r.subidas ?? 0) + (r.bajadas ?? 0)}
                      </td>
                    )}

                    <td class="px-3 py-3 md:px-6 md:py-4">{r.subidas ?? 0}</td>
                    <td class="px-3 py-3 md:px-6 md:py-4">{r.bajadas ?? 0}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- =========================
           GRUPO 2
      ========================== -->
      <div>
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-2xl md:text-3xl font-black text-white">Grupo 2</h2>
          <span class="text-zinc-400 text-sm">{group2.length} jugadores</span>
        </div>

        <!-- TOP 3 GRUPO 2 -->
        <div class="grid grid-cols-3 gap-2 md:gap-6 md:mb-10 mb-6">
          {top2.length > 0 ? (
            top2.map((p, i) => (
              <div class="rounded-2xl border border-zinc-800 bg-zinc-900/40 p-3 md:p-6">
                <p class="text-zinc-400 text-xs md:text-sm mb-1 md:mb-2">#{rankInList(all2, i)}</p>
                <p class="text-white text-sm md:text-xl font-bold truncate">{p.jugador}</p>
                <p class="text-lime-400 font-black text-base md:text-3xl mt-2 md:mt-4">
                  {p.puntos} <span class="text-lime-300/80 text-xs md:text-base">pts</span>
                </p>

                <!-- Grupo: solo desktop -->
                <div class="mt-3 md:mt-4 hidden md:block">
                  <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs border border-zinc-700 bg-zinc-900/60 text-zinc-200">
                    {groupLabel(p.grupo)}
                  </span>
                </div>

                <div class="mt-3 md:mt-6 text-xs md:text-sm text-zinc-300 space-y-1 md:space-y-2">
                  <!-- Partidos / Min pista: solo desktop -->
                    <p class="hidden md:block">
                      <span class="text-zinc-400">Partidos Jugados:</span> {(p.subidas ?? 0) + (p.bajadas ?? 0)}
                    </p>
                  <p><span class="text-zinc-400">Ganados:</span> {p.subidas ?? 0}</p>
                  <p><span class="text-zinc-400">Perdidos:</span> {p.bajadas ?? 0}</p>
                </div>
              </div>
            ))
          ) : (
            <div class="col-span-3 rounded-2xl border border-zinc-800 bg-zinc-900/40 p-6 text-zinc-300">
              No hay jugadores en el Grupo 2.
            </div>
          )}
        </div>

        <!-- TABLA GRUPO 2 -->
        <div class="rounded-2xl border border-zinc-800 bg-zinc-900/40 overflow-hidden">
          <div class="px-6 py-4 border-b border-zinc-800">
            <h3 class="text-white text-xl font-bold">Grupo 2</h3>
            <p class="text-zinc-400 text-sm mt-1">
              Ordenada por puntos · Empates: misma posición si tienen los mismos puntos.
            </p>
          </div>

          <div class="overflow-x-auto">
            <table class="min-w-full text-left text-sm">
              <thead class="text-zinc-400">
                <tr class="border-b border-zinc-800">
                  <th class="px-3 py-3 md:px-6 md:py-4 font-semibold">Pos.</th>
                  <th class="px-3 py-3 md:px-6 md:py-4 font-semibold">Jugador</th>

                  <th class="px-3 py-3 md:px-6 md:py-4 font-semibold hidden md:table-cell">Grupo</th>

