---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { clasificacionByYear } from "../../data/clasificacion";

export async function getStaticPaths() {
  return Object.keys(clasificacionByYear).map((year) => ({
    params: { year },
  }));
}

const { year } = Astro.params;
const rows = clasificacionByYear[year ?? ""] ?? [];

if (!rows.length) {
  throw new Error(`No hay datos de clasificación para el año ${year}`);
}

const sorted = [...rows].sort((a, b) => {
  const ga = a.grupo ?? 99;
  const gb = b.grupo ?? 99;
  if (ga !== gb) return ga - gb;

  const pa = a.puntos ?? 0;
  const pb = b.puntos ?? 0;
  if (pb !== pa) return pb - pa;

  const sa = a.subidas ?? 0;
  const sb = b.subidas ?? 0;
  if (sb !== sa) return sb - sa;

  const ba = a.bajadas ?? 0;
  const bb = b.bajadas ?? 0;
  if (ba !== bb) return ba - bb;

  return (a.jugador ?? "").localeCompare(b.jugador ?? "");
});

function groupLabel(g?: number) {
  if (!g) return "Sin grupo";
  if (g === 1) return "Grupo 1";
  if (g === 2) return "Grupo 2";
  return `Grupo ${g}`;
}

const group1 = sorted.filter((r) => (r.grupo ?? 0) === 1);
const group2 = sorted.filter((r) => (r.grupo ?? 0) === 2);

const top1 = group1.slice(0, 3);
const all1 = group1;

const top2 = group2.slice(0, 3);
const all2 = group2;

function rankInList(list: any[], idx: number) {
  if (idx === 0) return 1;

  const curr = list[idx];
  const prev = list[idx - 1];

  const samePoints = (curr.puntos ?? 0) === (prev.puntos ?? 0);

  if (samePoints) {
    for (let j = idx - 1; j >= 0; j--) {
      if (j === 0) return 1;

      const a = list[j];
      const b = list[j - 1];
      const pointsEq = (a.puntos ?? 0) === (b.puntos ?? 0);

      if (!pointsEq) return j + 1;
    }
    return 1;
  }

  return idx + 1;
}
---

<BaseLayout title={`Clasificación ${year} | Torneo Cumpleaños GR`}>
