---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { partidosByYear } from "../../data/partidos";

export async function getStaticPaths() {
  return Object.keys(partidosByYear).map((year) => ({
    params: { year },
  }));
}

const { year } = Astro.params;
const matches = partidosByYear[year ?? ""] ?? [];

if (!matches.length) {
  throw new Error(`No hay datos de partidos para el año ${year}`);
}

function groupLabel(g?: number) {
  if (!g) return "Sin grupo";
  return `Grupo ${g}`;
}

function partidoLabel(p?: number) {
  if (!p) return "Enfrentamientos";
  return `Partido ${p}`;
}

function isDefinedPair(pair?: string[]) {
  return !!pair && pair.length === 2 && pair.every((name) => name.trim() !== "Por definir");
}

const visibleMatches = matches.filter(
  (m) => isDefinedPair(m.pareja1) && isDefinedPair(m.pareja2)
);

const sorted = [...visibleMatches].sort((a, b) => {
  const ga = a.grupo ?? 99;
  const gb = b.grupo ?? 99;
  if (ga !== gb) return ga - gb;

  const pa = a.partido ?? 999;
  const pb = b.partido ?? 999;
  if (pa !== pb) return pa - pb;

  return a.pareja1.join(" ").localeCompare(b.pareja1.join(" "));
});

const uniqueGroups = [...new Set(sorted.map((m) => m.grupo ?? 0))].sort((a, b) => a - b);

const totalPartidos = sorted.length;
const jugados = sorted.filter((item) => !!item.resultado?.trim()).length;
const pendientes = totalPartidos - jugados;
---

<BaseLayout title={`Partidos ${year} | Torneo Cumpleaños GR`}>
  <section class="min-h-screen bg-zinc-950 text-white px-6 md:px-16 py-20">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-10">
        <div>
          <h1 class="text-4xl md:text-5xl font-black text-lime-400">
            Partidos {year}
          </h1>
          <p class="text-zinc-300 mt-4 max-w-2xl">
            Consulta los enfrentamientos entre parejas y el estado de cada partido del torneo.
          </p>
        </div>

        <div class="flex gap-3">
          <a
            href="/partidos/2025"
            class={`rounded-xl border px-4 py-2 text-sm font-semibold transition ${
              year === "2025"
                ? "border-lime-400 text-lime-400"
                : "border-zinc-700 text-zinc-300 hover:border-zinc-500"
            }`}
          >
            2025
          </a>
          <a
            href="/partidos/2026"
            class={`rounded-xl border px-4 py-2 text-sm font-semibold transition ${
              year === "2026"
                ? "border-lime-400 text-lime-400"
                : "border-zinc-700 text-zinc-300 hover:border-zinc-500"
            }`}
          >
            2026
          </a>
        </div>
      </div>

      <div class="grid md:grid-cols-3 gap-4 mb-8">
        <div class="rounded-2xl border border-zinc-800 bg-zinc-900/40 p-6">
          <p class="text-zinc-400 text-sm">Enfrentamientos totales</p>
          <p class="text-3xl font-black text-lime-400 mt-2">{totalPartidos}</p>
        </div>

        <div class="rounded-2xl border border-zinc-800 bg-zinc-900/40 p-6">
          <p class="text-zinc-400 text-sm">Jugados</p>
          <p class="text-3xl font-black text-lime-400 mt-2">{jugados}</p>
        </div>

        <div class="rounded-2xl border border-zinc-800 bg-zinc-900/40 p-6">
          <p class="text-zinc-400 text-sm">Pendientes</p>
          <p class="text-3xl font-black text-lime-400 mt-2">{pendientes}</p>
        </div>
      </div>

      <div class="flex flex-wrap gap-3 mb-12" id="group-filters">
        {uniqueGroups.map((group) => (
          <button
            type="button"
            data-group-filter={String(group)}
            class={`group-filter-btn rounded-xl border px-4 py-2 text-sm font-semibold transition ${
              group === 1
                ? "border-lime-400 text-lime-400"
                : "border-zinc-700 text-zinc-300 hover:border-zinc-500"
            }`}
          >
            {groupLabel(group)}
          </button>
        ))}
      </div>

      <div id="groups-wrapper">
        {uniqueGroups.map((group) => {
          const groupMatches = sorted.filter((m) => (m.grupo ?? 0) === group);
          const uniquePartidos = [...new Set(groupMatches.map((m) => m.partido ?? 0))].sort(
            (a, b) => a - b
          );

          return (
            <div class={`mb-16 group-section ${group !== 1 ? "hidden" : ""}`} data-group={group}>
              <div class="flex items-center justify-between mb-8">
                <h2 class="text-2xl md:text-3xl font-black text-white">
                  {groupLabel(group)}
                </h2>
                <span class="text-zinc-400 text-sm">
                  {groupMatches.length} enfrentamientos
                </span>
              </div>

              <div class="space-y-8">
                {uniquePartidos.map((partido) => {
                  const partidoMatches = groupMatches.filter(
                    (m) => (m.partido ?? 0) === partido
                  );

                  return (
                    <div class="rounded-2xl border border-zinc-800 bg-zinc-900/30 overflow-hidden">
                      <div class="px-6 py-4 border-b border-zinc-800 bg-zinc-900/60">
                        <div class="flex items-center justify-between gap-4 flex-wrap">
                          <h3 class="text-xl font-black text-lime-400">
                            {partidoLabel(partido)}
                          </h3>
                          <span class="text-sm text-zinc-400">
                            {partidoMatches.length} enfrentamientos
                          </span>
                        </div>
                      </div>

                      <div class="p-4 md:p-6 grid gap-4">
                        {partidoMatches.map((match) => {
                          const jugado = !!match.resultado?.trim();

                          return (
                            <article class="rounded-2xl border border-zinc-800 bg-zinc-950/70 overflow-hidden">
                              <div class="px-5 py-5 border-b border-zinc-800">
                                <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
                                  <div class="flex-1 text-center lg:text-left">
                                    <p class="text-white text-lg md:text-xl font-bold">
                                      {match.pareja1[0]} / {match.pareja1[1]}
                                    </p>
                                  </div>

                                  <div class="shrink-0 text-center">
                                    <span class="inline-flex items-center rounded-full px-3 py-1 text-xs border border-lime-400/40 text-lime-300 bg-lime-400/10 whitespace-nowrap">
                                      VS
                                    </span>
                                  </div>

                                  <div class="flex-1 text-center lg:text-right">
                                    <p class="text-white text-lg md:text-xl font-bold">
                                      {match.pareja2[0]} / {match.pareja2[1]}
                                    </p>
                                  </div>
                                </div>
                              </div>

                              <div class="p-4 md:p-5">
                                <div class="flex items-center justify-between gap-4 flex-wrap">
                                  <div>
                                    <p class="text-sm text-zinc-400 mb-2">Estado</p>
                                    <span
                                      class={`inline-flex items-center rounded-full px-2.5 py-1 text-[11px] font-semibold border whitespace-nowrap ${
                                        jugado
                                          ? "border-emerald-400/30 text-emerald-300 bg-emerald-400/10"
                                          : "border-amber-400/30 text-amber-300 bg-amber-400/10"
                                      }`}
                                    >
                                      {jugado ? "Jugado" : "Por jugar"}
                                    </span>
                                  </div>

                                  <div class="text-left md:text-right">
                                    <p class="text-sm text-zinc-400 mb-2">Resultado</p>
                                    {jugado ? (
                                      <p class="text-lime-400 font-black text-lg">
                                        {match.resultado}
                                      </p>
                                    ) : (
                                      <p class="text-zinc-400 text-sm">Pendiente</p>
                                    )}
                                  </div>
                                </div>
                              </div>
                            </article>
                          );
                        })}
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <script>
    const buttons = document.querySelectorAll<HTMLButtonElement>(".group-filter-btn");
    const sections = document.querySelectorAll<HTMLElement>(".group-section");

    function setActiveButton(value: string) {
      buttons.forEach((button) => {
        const isActive = button.dataset.groupFilter === value;

        button.classList.toggle("border-lime-400", isActive);
        button.classList.toggle("text-lime-400", isActive);
        button.classList.toggle("border-zinc-700", !isActive);
        button.classList.toggle("text-zinc-300", !isActive);
      });
    }

    function filterGroups(value: string) {
      sections.forEach((section) => {
        const shouldShow = section.dataset.group === value;
        section.classList.toggle("hidden", !shouldShow);
      });

      setActiveButton(value);
    }

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        const value = button.dataset.groupFilter ?? "1";
        filterGroups(value);
      });
    });

    filterGroups("1");
  </script>
</BaseLayout>