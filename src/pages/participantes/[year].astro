---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { participantesByYear } from "../../data/participantes";

export async function getStaticPaths() {
  return Object.keys(participantesByYear).map((year) => ({
    params: { year },
  }));
}

const { year } = Astro.params;
const players = participantesByYear[year ?? ""] ?? [];

if (!players.length) {
  throw new Error(`No hay datos de participantes para el año ${year}`);
}

const sorted = [...players].sort((a, b) => {
  const ga = a.grupo ?? 99;
  const gb = b.grupo ?? 99;
  if (ga !== gb) return ga - gb;

  return (a.nombre ?? "").localeCompare(b.nombre ?? "");
});

function groupLabel(g?: number) {
  if (!g) return "Sin grupo";
  return `Grupo ${g}`;
}

const uniqueGroups = [...new Set(sorted.map((p) => p.grupo ?? 0))].sort((a, b) => a - b);
const totalPlayers = sorted.length;
---

<BaseLayout title={`Participantes ${year} | Torneo Cumpleaños GR`}>
  <section class="min-h-screen bg-zinc-950 text-white px-6 md:px-16 py-20">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-10">
        <div>
          <h1 class="text-4xl md:text-5xl font-black text-lime-400">
            Participantes {year}
          </h1>
          <p class="text-zinc-300 mt-4 max-w-2xl">
            Conoce a todos nuestros jugadores que forman parte del torneo,
            distribuidos por grupos para seguir mejor la competición.
          </p>
        </div>

        <div class="flex gap-3">
          <a
            href="/participantes/2025"
            class={`rounded-xl border px-4 py-2 text-sm font-semibold transition ${
              year === "2025"
                ? "border-lime-400 text-lime-400"
                : "border-zinc-700 text-zinc-300 hover:border-zinc-500"
            }`}
          >
            2025
          </a>
          <a
            href="/participantes/2026"
            class={`rounded-xl border px-4 py-2 text-sm font-semibold transition ${
              year === "2026"
                ? "border-lime-400 text-lime-400"
                : "border-zinc-700 text-zinc-300 hover:border-zinc-500"
            }`}
          >
            2026
          </a>
        </div>
      </div>

      <!-- RESUMEN -->
      <div class="grid md:grid-cols-3 gap-4 mb-12">
        <div class="rounded-2xl border border-zinc-800 bg-zinc-900/40 p-6">
          <p class="text-zinc-400 text-sm">Participantes</p>
          <p class="text-3xl font-black text-lime-400 mt-2">{totalPlayers}</p>
        </div>

        <div class="rounded-2xl border border-zinc-800 bg-zinc-900/40 p-6">
          <p class="text-zinc-400 text-sm">Grupos</p>
          <p class="text-3xl font-black text-lime-400 mt-2">{uniqueGroups.filter(Boolean).length}</p>
        </div>

        <div class="rounded-2xl border border-zinc-800 bg-zinc-900/40 p-6">
          <p class="text-zinc-400 text-sm">Ubicación</p>

          {              year === "2026"
                ? <p class="text-3xl font-black text-lime-400 mt-2">MutxoPadel</p>
                : <p class="text-3xl font-black text-lime-400 mt-2">Padel Premium</p>
            }
        </div>
      </div>

      {uniqueGroups.map((group) => {
        const groupPlayers = sorted.filter((p) => (p.grupo ?? 0) === group);

        return (
          <div class="mb-14">
            <div class="flex items-center justify-between mb-6">
              <h2 class="text-2xl md:text-3xl font-black text-white">
                {groupLabel(group)}
              </h2>
              <span class="text-zinc-400 text-sm">
                {groupPlayers.length} participantes
              </span>
            </div>

            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
              {groupPlayers.map((p) => (
                <article class="rounded-2xl border border-zinc-800 bg-zinc-900/40 p-5 md:p-6 hover:border-lime-400/30 transition">
                  <div class="flex items-start justify-between gap-4">
                    <div class="flex row gap-2">
                      <h3 class="text-lg md:text-xl font-bold text-white">
                        {p.nombre}
                      </h3>

                      {p.apodo && (
                        <p class="text-zinc-400 text-sm mt-1">
                          “{p.apodo}”
                        </p>
                      )}
                    </div>

                    <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs border border-lime-400/40 text-lime-300 bg-lime-400/10">
                      {groupLabel(p.grupo)}
                    </span>
                  </div>

                  <div class="mt-5 space-y-2 text-sm text-zinc-300">
                    {p.pareja && (
                      <p>
                        <span class="text-zinc-400">Pareja:</span> {p.pareja}
                      </p>
                    )}

                    {p.posicion && (
                      <p>
                        <span class="text-zinc-400">Posición:</span> {p.posicion}
                      </p>
                    )}

                    {p.edad && (
                      <p>
                        <span class="text-zinc-400">Edad:</span> {p.edad}
                      </p>
                    )}
                  </div>

                  {p.descripcion && (
                    <p class="mt-5 text-sm text-zinc-300 leading-relaxed border-t border-zinc-800 pt-4">
                      {p.descripcion}
                    </p>
                  )}
                </article>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </section>
</BaseLayout>