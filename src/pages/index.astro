---
import "../styles/global.css";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <section class="relative flex h-screen items-center justify-center overflow-hidden">
    <img
      src="/src/public/fondo.png"
      alt="Pista de pádel"
      class="pointer-events-none absolute inset-0 h-full w-full object-cover"
    />
    <div class="pointer-events-none absolute inset-0 bg-black/30"></div>

    <div
      id="introAnim"
      class="
         absolute
         -translate-x-1/2
        top-1/2 -translate-y-1/2
        flex items-center gap-20
        left-0 md:-translate-x-1/3
        md:gap-150
      "
    >
      <span id="palaWrap" class="block">
        <img
          id="palaImg"
          src="/src/public/pala-german3.png"
          alt="Pala de padel"
          class="
            h-140 w-auto md:h-300 md:w-auto
          "
        />
      </span>

      <button id="participarBtn" type="button" class="shrink-0">
        <span id="ballWrap" class="block">
          <img
            src="/src/public/pelota-boton.png"
            alt="Pelota de padel"
            class="
              pointer-events-none
              h-16 w-16

              md:h-30 md:w-30
            "
          />
        </span>
      </button>
    </div>
  </section>

  <script is:inline>
  window.addEventListener("DOMContentLoaded", () => {
    const container = document.getElementById("introAnim");
    const btn = document.getElementById("participarBtn");
    const palaWrap = document.getElementById("palaWrap");
    const palaImg = document.getElementById("palaImg");
    const ball = document.getElementById("ballWrap");

    if (!container || !btn || !palaWrap || !palaImg || !ball || !window.gsap) return;

    const LS_KEY = "introAnimDone";

    if (localStorage.getItem(LS_KEY) === "1") {
      container.style.display = "none";
      return;
    }

    let running = false;

    const mm = window.gsap.matchMedia();

    btn.addEventListener("click", () => {
      if (running) return;
      running = true;
      btn.disabled = true;

      if (btn._tl && btn._tl.kill) btn._tl.kill();

      mm.add(
        {
          isDesktop: "(min-width: 768px)",
          isMobile: "(max-width: 767px)",
        },
        (context) => {
          const { isDesktop, isMobile } = context.conditions;

          let palaX1 = 800;
          let palaX2 = 900;
          let palaRot1 = 20;
          let palaRot2 = 35;

          let ballScale1 = 6;
          let ballScale2 = 200;
          let ballBlur = 8;

          if (isMobile) {

            palaX1 = Math.min(300, window.innerWidth * 0.55);
            palaX2 = Math.min(380, window.innerWidth * 0.50);
            palaRot1 = 16;
            palaRot2 = 28;

            ballScale1 = 4.5;
            ballScale2 = 90;
            ballBlur = 6;
          }

          const tl = window.gsap.timeline({
            onComplete: () => {
              running = false;
              localStorage.setItem(LS_KEY, "1");
              container.style.display = "none";
            },
          });

          btn._tl = tl;

          tl.to(palaWrap, {
            duration: 0.7,
            y: "70px",
            x: palaX1,
            rotation: palaRot1,
            ease: "power2.in",
          });

          tl.call(() => {
            palaImg.src = "/src/public/pala-german2.png";
          });

          tl.to(palaWrap, {
            duration: 0.06,
            x: palaX2,
            rotation: palaRot2,
            ease: "power1.in",
          });

          tl.call(() => {
            palaImg.src = "/src/public/pala-german1.png";
          });

          tl.to(
            ball,
            {
              duration: 1.8,
              scale: ballScale1,
              rotation: 360,
              ease: "power3.in",
              transformOrigin: "center center",
            },
            "<"
          )
            .to(ball, {
              duration: 1.2,
              scale: ballScale2,
              filter: `blur(${ballBlur}px)`,
              opacity: 0,
              ease: "power2.out",
            })
            .to(
              palaWrap,
              {
                duration: 0.01,
                opacity: 0,
                rotation: palaRot1,
                ease: "power2.in",
              },
              "<"
            );

          return () => {
            if (tl && tl.kill) tl.kill();
          };
        }
      );
    });
  });
</script>
</BaseLayout>