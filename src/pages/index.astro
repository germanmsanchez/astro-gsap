---
import "../styles/global.css";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <section class="relative flex h-screen items-center justify-center overflow-hidden">
    <img
      src="/src/public/fondo.png"
      alt="Pista de pádel"
      class="pointer-events-none absolute inset-0 h-full w-full object-cover"
    />
    <div class="pointer-events-none absolute inset-0 bg-black/30"></div>

    <div id="introAnim" class="absolute left-0 -translate-x-1/3 top-1/2 -translate-y-1/2 flex items-center gap-150">

		<span id="palaWrap" class="block">
			<img
			id="palaImg"
			src="/src/public/pala-german3.png"
			alt="Pala de padel"
			class="h-300 w-auto pointer-events-none"
			/>
		</span>

		<button id="participarBtn" type="button">
			<span id="ballWrap" class="block">
			<img
				src="/src/public/pelota-boton.png"
				alt="Pelota de padel"
				class="h-30 w-30 pointer-events-none"
			/>
			</span>
		</button>

	</div>
  </section>

  <script is:inline>
  window.addEventListener("DOMContentLoaded", () => {
	const container = document.getElementById("introAnim");
    const btn = document.getElementById("participarBtn");
    const palaWrap = document.getElementById("palaWrap");
    const palaImg = document.getElementById("palaImg");
    const ball = document.getElementById("ballWrap");

    if (!container || !btn || !palaWrap || !palaImg || !ball || !window.gsap) return;

	const LS_KEY = "introAnimDone";

	if (localStorage.getItem(LS_KEY) === "1") {
      container.style.display = "none";
      return;
    }

    let running = false;

    btn.addEventListener("click", () => {
      if (running) return;
      running = true;

	  btn.disabled = true;

      const tl = window.gsap.timeline({
        onComplete: () => {
          running = false;
          localStorage.setItem(LS_KEY, "1");
          container.style.display = "none";
        },
      });

      tl.to(palaWrap, {
        duration: 0.7,
        x: 800,
        rotation: 20,
        ease: "power2.in",
      });
      tl.call(() => {
        palaImg.src = "/src/public/pala-german2.png";
      });
      tl.to(palaWrap, {
        duration: 0.06,
        x: 900,
        rotation: 35,
        ease: "power1.in",
      });
      tl.call(() => {
        palaImg.src = "/src/public/pala-german1.png";
      });
tl.to(
  ball,
  {
    duration: 1.8,
    scale: 6,
    rotation: 360,
    ease: "power3.in",
    transformOrigin: "center center",
  },
  "<"
)
.to(ball, {
  duration: 1.2,
  scale: 200,
  filter: "blur(8px)",
  opacity: 0,
  ease: "power2.out",
})
.to(palaWrap, {
  duration: 0.01,
  opacity: 0,
  rotation: 20,
  ease: "power2.in",
},
"<");
    });
  });
</script>

</BaseLayout>
